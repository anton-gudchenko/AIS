<Window x:Class="Practice5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Practice5"
        mc:Ignorable="d"
        Title="Перцептрон" Height="720" Width="1280">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Label Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" FontSize="14" Content="Свойства нейросети: " x:Name="NetworkStats" />
        
        <WrapPanel Grid.Column="0" Grid.Row="1" Orientation="Vertical">
            <GroupBox Header="Настройки нейросети" Margin="5,5,5,0" FontSize="14" Padding="2">
                <StackPanel Orientation="Vertical">
                    <RadioButton Content="По умолчанию" Tag="default" FontSize="14" Checked="NetworkTypeButton" IsChecked="True" />
                    <RadioButton Content="Настраиваемая" Tag="custom" FontSize="14" Checked="NetworkTypeButton" />
                    <WrapPanel Visibility="Collapsed" Orientation="Vertical" x:Name="CustomPanel">
                        <Label Content="Входной слой: 9 нейронов" />
                        <DockPanel>
                            <Label Content="Скрытые слои: " />
                            <TextBox Width="150" FontSize="14" Padding="2" x:Name="HiddenLayers" />
                        </DockPanel>
                        <Label Content="Выходной слой: 6 нейронов" />
                        <WrapPanel HorizontalAlignment="Right">
                            <Button Content="Инициализировать" Margin="5" FontSize="14" Padding="5,2,5,2" />
                        </WrapPanel>
                    </WrapPanel>
                    <RadioButton Content="Существующая" Tag="import" FontSize="14" Checked="NetworkTypeButton" />
                    <WrapPanel Visibility="Collapsed" x:Name="FilePanel">
                        <TextBox FontSize="14" MinWidth="200" Margin="2" Padding="2" IsReadOnly="True" x:Name="NetworkPath" />
                        <Button Content="Обзор" Margin="2" Padding="5,2,5,2" Click="ExploreButton_Click" />
                    </WrapPanel>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Обучение нейросети" Margin="5,5,5,0" FontSize="14" Padding="2">
                <StackPanel Orientation="Vertical" Width="Auto">
                    <Label Content="Определяемые образы:" />
                    <Grid x:Name="TrainingGrid" ShowGridLines="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <Label Grid.Column="0" Grid.Row="0" FontWeight="Bold" Content="Номер" />
                        <Label Grid.Column="1" Grid.Row="0" FontWeight="Bold" Content="Значение" />

                        <Label Grid.Column="0" Grid.Row="1" Content="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Label Grid.Column="0" Grid.Row="2" Content="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Label Grid.Column="0" Grid.Row="3" Content="3" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Label Grid.Column="0" Grid.Row="4" Content="4" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Label Grid.Column="0" Grid.Row="5" Content="5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Grid.Row="1"/>
                    </Grid>
                    <Label Content="Коэффициент обучения:" />
                    <TextBox Margin="5" Padding="2,5,2,5" x:Name="TraningCoefficient" Text="1" />
                    <Button Content="Начать обучение" Margin="5" Padding="5,2,5,2" HorizontalAlignment="Right" Click="TrainingButton_Click" />
                    <Button Content="Сбросить настройки" Margin="5" Padding="5,2,5,2" HorizontalAlignment="Right" Click="ResetButton_Click" />
                </StackPanel>
            </GroupBox>
        </WrapPanel>

        <WrapPanel Grid.Column="1" Grid.Row="1" Orientation="Vertical" x:Name="MainPanel">
            <Label Content="Задайте образ:" Margin="5" FontSize="20" FontWeight="Bold" />
            <Label Content="Ответ перцептрона:" Margin="5" FontSize="20" x:Name="Result" />
        </WrapPanel>
    </Grid>
</Window>
