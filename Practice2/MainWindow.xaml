<Window x:Class="Practice2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Practice2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <WrapPanel>
            <Label Content="Введите количество блоков на первой башне:" />
            <TextBox Margin="5" Width="200" x:Name="InitialBlocksText" />
            <Button Content="Решить" Margin="5" Click="SolveButton_Click" x:Name="SolveButton" />
            <TextBlock Margin="5" x:Name="StepsCount" />
        </WrapPanel>

        <ListView Grid.Row="1" x:Name="Steps" />
    </Grid>
</Window>
