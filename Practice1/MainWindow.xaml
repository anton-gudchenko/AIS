<Window x:Class="Practice1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Practice1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <DockPanel Grid.ColumnSpan="2" Margin="10,10,10,10">
            <Label Content="Ниже отображается список с выполненными действиями" Width="328"/>
            <Button x:Name="StartButton" Content="Запустить" Width="57.73" HorizontalAlignment="Right" Click="Start_Click"/>
        </DockPanel>
        <ListView x:Name="SolutionPath" Foreground="Black" FontFamily="Cascadia Code" Grid.Row="1" FontSize="20">
            
        </ListView>
    </Grid>
</Window>
